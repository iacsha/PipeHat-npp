#include <windows.h>
#include <commctrl.h>
#include "resource.h"

// Dialog 1 — the dockable Message Tree panel. Its TreeView is created in code
// (MessageTreeView::dlgProc), so the template is intentionally empty.
1 DIALOGEX 0, 0, 300, 400
STYLE WS_CHILD
EXSTYLE 0
BEGIN
END

// Dialog 2 (IDD_SETTINGS) — PipeHat settings: conformance rules plus the MLLP
// network section. Conformance rules persist to PipeHat.profile; MLLP settings
// to PipeHat.ini.
IDD_SETTINGS DIALOGEX 0, 0, 344, 322
STYLE DS_MODALFRAME | DS_CENTER | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "PipeHat Settings"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Conformance rules that Check Conformance applies to the active message. One row per segment-field.",
                    -1, 7, 6, 330, 16
    CONTROL         "", IDC_RULE_LIST, "SysListView32",
                    LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP,
                    7, 24, 330, 120
    PUSHBUTTON      "&Add...", IDC_RULE_ADD, 7, 148, 52, 14
    PUSHBUTTON      "&Edit...", IDC_RULE_EDIT, 63, 148, 52, 14
    PUSHBUTTON      "&Remove", IDC_RULE_REMOVE, 119, 148, 52, 14

    GROUPBOX        "MLLP (network) - HL7 over TCP", -1, 7, 170, 330, 118
    AUTOCHECKBOX    "Enable MLLP networking (off by default)", IDC_MLLP_ENABLE, 14, 184, 200, 10
    LTEXT           "Send to Host:", -1, 14, 202, 54, 10
    EDITTEXT        IDC_MLLP_HOST, 70, 200, 120, 12, ES_AUTOHSCROLL
    LTEXT           "Port:", -1, 200, 202, 20, 10
    EDITTEXT        IDC_MLLP_SENDPORT, 222, 200, 40, 12, ES_NUMBER | ES_AUTOHSCROLL
    LTEXT           "Listener port:", -1, 14, 220, 54, 10
    EDITTEXT        IDC_MLLP_LISTENPORT, 70, 218, 40, 12, ES_NUMBER | ES_AUTOHSCROLL
    AUTOCHECKBOX    "Allow binding a non-loopback interface (exposes a receiver on your network)",
                    IDC_MLLP_ALLOWNONLOOP, 14, 236, 320, 10
    LTEXT           "Bind address:", -1, 14, 252, 54, 10
    EDITTEXT        IDC_MLLP_BINDADDR, 70, 250, 120, 12, ES_AUTOHSCROLL
    LTEXT           "Warning: MLLP is cleartext - PHI crosses the network unencrypted. Keep to loopback / trusted networks.",
                    -1, 14, 270, 320, 14

    DEFPUSHBUTTON   "&Save", IDOK, 229, 300, 52, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 285, 300, 52, 14
    LTEXT           "Rules -> PipeHat.profile, network -> PipeHat.ini (plugin config folder).",
                    -1, 7, 304, 260, 10
END

// Dialog 3 (IDD_RULE) — add or edit a single conformance rule.
IDD_RULE DIALOGEX 0, 0, 224, 156
STYLE DS_MODALFRAME | DS_CENTER | DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Conformance Rule"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Segment:", -1, 7, 10, 44, 10
    EDITTEXT        IDC_RULE_SEG, 66, 8, 52, 12, ES_UPPERCASE | ES_AUTOHSCROLL
    LTEXT           "Field #:", -1, 7, 27, 44, 10
    EDITTEXT        IDC_RULE_FIELD, 66, 25, 44, 12, ES_NUMBER | ES_AUTOHSCROLL
    AUTOCHECKBOX    "Max length", IDC_RULE_MAXCHK, 7, 45, 55, 10
    EDITTEXT        IDC_RULE_MAX, 66, 43, 44, 12, ES_NUMBER | ES_AUTOHSCROLL
    AUTOCHECKBOX    "Allowed values (comma-separated)", IDC_RULE_VALCHK, 7, 62, 160, 10
    EDITTEXT        IDC_RULE_VALUES, 7, 74, 210, 12, ES_AUTOHSCROLL
    AUTOCHECKBOX    "Required (field must be present)", IDC_RULE_REQ, 7, 92, 160, 10
    LTEXT           "For MSH, use HL7 field numbers (MSH-9, MSH-12...).",
                    -1, 7, 110, 210, 10
    DEFPUSHBUTTON   "OK", IDOK, 111, 132, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 167, 132, 50, 14
END
